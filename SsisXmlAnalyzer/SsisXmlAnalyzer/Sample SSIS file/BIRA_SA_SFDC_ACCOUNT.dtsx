                      refId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\LOAD TBL SFDC ACCOUNT STAGING.Outputs[OLE DB Destination Error Output]"
                      exclusionGroup="1"
                      isErrorOut="true"
                      name="OLE DB Destination Error Output"
                      synchronousInputId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\LOAD TBL SFDC ACCOUNT STAGING.Inputs[OLE DB Destination Input]">
                      <outputColumns>
