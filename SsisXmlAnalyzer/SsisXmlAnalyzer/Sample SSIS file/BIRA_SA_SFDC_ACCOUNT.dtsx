                </component>
                <component
                  refId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="OLE_SRC Get Account Data"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT c.CUST_NAME AS BUS_ORG_NAME
    ,c.CUST_NBR AS BUS_ORG_ID
    ,c.CUST_COUNTRY_NAME AS SALES_COUNTRY
    ,ca.rpt_gl_profit_ctr_gm_cd AS SUB_REGION /* formerly account_region__c per Cust Attribute documentation */                                                
    ,ca.sales_chan_bus_group_name AS SALES_DIVISION /* formerly a.account_division__c per Cust Attribute documentation; field is in blue in SQL tab so not sure if changing */                                                 
    ,ca.sales_office_name AS SALES_OFFICE /* formerly account_sales_office__c per Mapping tab in Cust Attribute documentation */                                 
    ,e.emp_department_name AS SALES_OFFICE_OWNER /* formerly a.owner_sales_office__c; e.emp_department_name is closest match for now */
    ,ca.external_rpt_sales_chan_name AS REPORTING_SALES_CHANNEL /* Cust Attribute documentation indicates logic is not ready yet so need to recheck; formerly a.external_reporting_rollup__c */                                                                 
    ,NULL AS SALES_CHANNEL_OWNER /* formerly a.owner_sales_channel__c; testing for NULL */
    ,REPLACE(REPLACE(ca.Sales_Chan_Name, 'T4_', ''), 'T5_', '') AS SALES_CHANNEL /* Cust Attribute documentation indicates logic is not ready yet so need to recheck; formerly a.account_channel__c */                           
    ,REPLACE(REPLACE(ca.sales_sub_chan_name, 'T4_', ''), 'T5_', '') AS SALES_SUB_CHANNEL /* Cust Attribute documentation indicates logic is not ready yet so need to recheck; formerly a.account_sub_channel__c */                                                  
    ,NULL AS SEGMENT /* formerly a.account_segment__c; testing for NULL */           
    ,NULL AS SUB_SEGMENT /* formerly a.account_sub_segment__c; testing for NULL */
    ,ca.industry_vertical_typ AS MARKET_VERTICAL /* formerly a.market_vertical__c per Cust Attribute documentation */                                   
    ,ca.industry_sub_vertical_typ AS MARKET_SUB_VERTICAL /* formerly a.market_sub_vertical__c per Cust Attribute documentation */               
    ,ser.sales_region_name AS SALES_REGION_OWNER /* formerly a.owner_region__c; now SALES_EXEC_TEXT__C; not exact match; populates Customer Tier in loyalty downstream */                                                  
    ,NULL AS SALES_DIVISION_OWNER /* formerly owner_division__c; was used in CSAT loyalty but testing for NULL */
    ,eman.emp_first_name || ' ' || eman.emp_last_name AS MANAGER_OWNER
    ,eman.employee_nbr AS SOURCE_MANAGER_EMPLOYEE_NBR /* this is go-forward id number; pulling in to keep original format but will join on downstream GAL table to get "former" person id */                                                       
    ,e.emp_full_name AS PRIMARY_AM_NAME /* formerly ua.lastname || ', ' || ua.firstname || ' (' || ua.firstname || ')' */
    ,e.employee_nbr AS SOURCE_EMPLOYEE_NBR /* this is go-forward id number; pulling in to keep original format but will join on downstream GAL table to get "former" person id */                                            
    ,e.emp_email_addr AS PRIMARY_AM_EMAIL /* new to table */                          
    ,e.emp_job_title_name AS PRIMARY_AM_OWNER_TYPE /* formerly ua.title */              
    ,e.emp_region_name AS PRIMARY_AM_REGION
    ,ca.service_level_typ AS SERVICE_LEVEL /* formerly a.service_level__c per Cust Attribute documentation */                                            
    ,CASE 
        WHEN c.CUST_NBR LIKE '2-%'
            THEN 'ftw'
        ELSE 'flvlt'
        END AS LEGACY_COMPANY
    ,CASE 
        WHEN (
                ca.lvlt_target_tier_name IS NULL
                OR ca.lvlt_target_tier_name NOT IN ('Tier 1', 'Tier 2', 'Tier 3', 'SEAT')
                )
            THEN 'NM'
        ELSE ca.lvlt_target_tier_name
        END AS CUSTOMER_TIER /* formerly a.target_tier__C per Cust Attribute documentation */                              
    ,CASE 
        WHEN uc.global_acct_mgmt_ind = 'N'
            THEN 'No'
        ELSE 'Yes'
        END AS GAM
    ,c.ultimate_cust_nbr AS Ultimate_Cust_Num
    ,c.ultimate_cust_name AS Ultimate_Customer_Name
    ,CASE 
        WHEN csm.CSM_1_NAME IS NOT NULL
            THEN 'Yes'
        ELSE 'No'
        END AS CSM_FLAG
    ,csm.CSM_1_NAME AS CSM_NAME_1
    ,csm.CSM_1_EMAIL AS CSM_EMAIL_1
    ,csm.CSM_1_EMPLOYEE_NBR AS CSM_EMPLOYEE_NBR_1
    ,csm.CSM_2_NAME AS CSM_NAME_2
    ,csm.CSM_3_NAME AS CSM_NAME_3
    ,csm.CSM_4_NAME AS CSM_NAME_4
    ,csm.CSM_5_NAME AS CSM_NAME_5
    ,CASE 
        WHEN osm.OSM_NAME IS NOT NULL
            THEN 'Yes'
        ELSE 'No'
        END AS OSM_FLAG
    ,osm.OSM_NAME
    ,osm.OSM_EMAIL
    ,vp.name AS RVP_Name
    ,NVL(vp.EMPLOYEENUMBER, vp.FEDERATIONIDENTIFIER) AS RVP_Employee_Nbr
    ,vp_emp.emp_user_name AS RVP_Login
    ,vp_emp.emp_email_addr AS RVP_Email
    ,ser.Sales_Territory_Name AS GM_Market_SFDC /* formerly a.GM__C; per Sales Employee Role DOC, it's coming from USER.GM_TEXT__C, which should be same */                                                 
    ,gm.name AS General_Manager_VP_Name
    ,NVL(gm.EMPLOYEENUMBER, gm.FEDERATIONIDENTIFIER) AS GM_Employee_Nbr
    ,gm_emp.emp_user_name AS GM_NT_Login
    ,gm_emp.emp_email_addr AS GM_Email
    ,SUBSTR(lob.GL_LOB_ESS_TIER3_DESC, 1, 237) AS BU_SOURCE                    
    ,c.cust_contact_name
    ,c.cust_contact_email_addr
    ,c.cust_phone_nbr
    ,sp.SP_Name
    ,sp.SP_Employee_Nbr
    ,sfu.lead_text__c AS account_sales_channel
    ,sfa.account_owner_sales_region__c AS ACCT_OWNER_SALES_REGION
    ,sfa.sd_plus__c AS SD_PLUS
    ,CASE 
        WHEN dm.emp_manager_ods_id IS NULL
            THEN eman.emp_full_name
        ELSE e.emp_full_name
        END AS Tier2_Manager
    ,CASE 
        WHEN dm.emp_manager_ods_id IS NULL
            THEN eman.employee_nbr
        ELSE e.employee_nbr
        END AS Tier2_Manager_Nbr
    ,ca.lob_id
    ,dir.name AS Director_Name
    ,nvl(dir.employeenumber, dir.federationidentifier) AS Director_Employee_Nbr
    ,sfa.id account_id
    ,REPLACE(lob.gl_lob_ess_tier5_desc, 'T5_', '') bu_subcategory
    ,c.sales_rep_id
    ,sfa.enterprise_target_group_in_cou
    ,REPLACE(lob.gl_lob_ess_tier4_desc, 'T4_', '') as bu_layer_2
    ,lob.gl_lob_ess_tier0_desc
    ,lob.gl_lob_ess_tier1_desc
    ,lob.gl_lob_ess_tier2_desc
    ,lob.gl_lob_ess_tier6_desc
    ,lob.gl_lob_ess_tier7_desc
    ,lob.gl_lob_ess_tier8_desc
    ,lob.gl_lob_ess_tier9_desc
    ,lob.gl_lob_ess_tier10_desc
    ,lob.gl_lob_ess_tier11_desc 
    ,lob.gl_lob_ess_tier3_desc
    ,lob.gl_lob_ess_tier4_desc
    ,lob.gl_lob_ess_tier5_desc
    ,dl.sales_as_managed
    ,dl.sales_segment_leader
    ,dl.sales_segment_leader_name   
    ,dl.cs_as_managed
    ,dl.cs_segment_leader
    ,dl.cs_segment_leader_name
    ,lob.gl_lob_desc as lob_description
    ,dl.market
    ,dl.market_alias
    ,dl.gm_market  
    ,cso.name as cs_owner_name
    ,cso.employeenumber as cs_owner_emp_nbr
    ,cso.cuid__c as cs_owner_cuid
    ,c.dw_secure_company_nbr
FROM CODS.CUSTOMER c
LEFT OUTER JOIN CODS.CUSTOMER_ATTRIBUTION ca
    ON c.cust_ods_id = ca.cust_ods_id
LEFT OUTER JOIN CODS.ULTIMATE_CUSTOMER uc
    ON c.ultimate_cust_ods_id = uc.ultimate_cust_ods_id
LEFT OUTER JOIN CODS.EMPLOYEE e
    ON c.prim_sales_emp_ods_id = e.employee_ods_id
LEFT OUTER JOIN CODS.EMPLOYEE eman
    ON e.emp_manager_ods_id = eman.employee_ods_id
LEFT OUTER JOIN CODS.SALES_EMPLOYEE_ROLE ser
    ON e.Sales_Emp_Role_Ods_Id = ser.sales_emp_role_ods_id
LEFT OUTER JOIN CODS_FINANCE.V_GL_SEG3_LOB_ACTIVE lob
    ON ca.lob_id = lob.GL_LOB_CD
LEFT OUTER JOIN FISCDM.DIM_LOB dl
    ON ca.lob_id = dl.lob_id
LEFT OUTER JOIN /* this pulls in all the first five CSMs listed on account */
    (
    SELECT BUS_ORG_ID
        ,CSM_1_NAME
        ,CSM_1_EMAIL
        ,CSM_1_EMPLOYEE_NBR
        ,CSM_2_NAME
        ,CSM_3_NAME
        ,CSM_4_NAME
        ,CSM_5_NAME
    FROM (
        SELECT DISTINCT e.emp_full_name AS CSM_NAME
            ,at.cust_nbr AS BUS_ORG_ID
            ,e.emp_email_addr AS CSM_EMAIL_1
            ,e.employee_nbr AS CSM_EMPLOYEE_NBR_1
            ,ROW_NUMBER() OVER (
                PARTITION BY at.cust_nbr ORDER BY at.source_create_dt
                ) AS CSM_NM
        FROM CODS.EMPLOYEE e
        LEFT OUTER JOIN CODS.ACCOUNT_TEAM at
            ON e.employee_ods_id = at.emp_ods_id
        WHERE at.emp_position_cd = 'Client Service Manager'
        ) csm
    PIVOT(MIN(CSM_NAME) AS NAME, MIN(CSM_EMAIL_1) AS EMAIL, MIN(CSM_EMPLOYEE_NBR_1) AS EMPLOYEE_NBR FOR CSM_NM IN (1 AS CSM_1, 2 AS CSM_2, 3 AS CSM_3, 4 AS CSM_4, 5 AS CSM_5))
    ) csm
    ON c.CUST_NBR = csm.BUS_ORG_ID
LEFT OUTER JOIN /* this pulls in the OSM listed on account */
    (
    SELECT OSM_NAME
        ,BUS_ORG_ID
        ,OSM_EMAIL
        ,OSM_NM
    FROM (
        SELECT DISTINCT e.emp_full_name AS OSM_NAME
            ,at.cust_nbr AS BUS_ORG_ID
            ,e.emp_email_addr AS OSM_EMAIL
            ,ROW_NUMBER() OVER (
                PARTITION BY at.cust_nbr ORDER BY at.source_create_dt
                ) AS OSM_NM
        FROM CODS.EMPLOYEE e
        LEFT OUTER JOIN CODS.ACCOUNT_TEAM at
            ON e.employee_ods_id = at.emp_ods_id
        WHERE at.emp_position_cd = 'Operational Service Manager'
        )
    WHERE OSM_NM = 1 /* there should only be one OSM per Bus Org but added this filter just in case */
    ) osm
    ON c.CUST_NBR = osm.BUS_ORG_ID
LEFT OUTER JOIN /* this pulls in the Sales President */
    (
    SELECT *
    FROM (
        SELECT c.cust_nbr
            ,e.emp_full_name AS SP_Name
            ,e.employee_nbr AS SP_Employee_Nbr
            ,ROW_NUMBER() OVER (
                PARTITION BY c.CUST_NBR ORDER BY scr.SOURCE_LAST_MODIFY_DT DESC
                ) seq
        FROM cods.customer c
        INNER JOIN CODS.SOURCE_CONTACT_ROLE scr
            ON C.CUST_ODS_ID = SCR.CUST_ODS_ID
        INNER JOIN CODS.SOURCE_CONTACT sc
            ON scr.source_contact_ods_id = SC.SOURCE_CONTACT_ODS_ID
        LEFT OUTER JOIN CODS.Employee e
            ON sc.employee_ods_id = e.employee_ods_id
        WHERE scr.dw_source_system_cd IN ('SFDC')
            AND scr.context_typ = 'ACCOUNT_SALES_OFFICE'
            AND scr.role_name = 'Sales President'
        )
    WHERE seq = 1 /* there should only be one Sales President per Bus Org: example '2-CB9CWN'*/
    ) sp
    ON c.CUST_NBR = sp.cust_nbr
LEFT OUTER JOIN (
    SELECT DISTINCT emp_manager_ods_id
    FROM CODS.EMPLOYEE
    ) dm
    ON dm.emp_manager_ods_id = e.employee_ods_id
LEFT OUTER JOIN crpl_salesforce_ctl.account sfa
    ON sfa.account_number__c = c.cust_nbr
LEFT OUTER JOIN crpl_salesforce_ctl."USER" sfu
    ON sfa.ownerid = sfu.id
LEFT OUTER JOIN crpl_salesforce_ctl."USER" vp
    ON sfu.vp__c = vp.id
LEFT OUTER JOIN crpl_salesforce_ctl."USER" dir
    ON sfu.director__c = dir.id
LEFT OUTER JOIN crpl_salesforce_ctl."USER" gm
    ON sfu.sr_director_gm__c = gm.id
LEFT OUTER JOIN cods.employee vp_emp
    ON vp_emp.employee_nbr = nvl(vp.EMPLOYEENUMBER, vp.FEDERATIONIDENTIFIER)
LEFT OUTER JOIN cods.employee dir_emp
    ON dir_emp.employee_nbr = nvl(dir.EMPLOYEENUMBER, dir.FEDERATIONIDENTIFIER)
LEFT OUTER JOIN cods.employee gm_emp
    ON gm_emp.employee_nbr = nvl(gm.EMPLOYEENUMBER, gm.FEDERATIONIDENTIFIER)
LEFT OUTER JOIN crpl_salesforce_ctl."USER" cso
    ON sfa.csp__c = cso.id
/*
WHERE nvl(c.dw_secure_company_nbr,0) not in (2)
*/</property>
                    <property
