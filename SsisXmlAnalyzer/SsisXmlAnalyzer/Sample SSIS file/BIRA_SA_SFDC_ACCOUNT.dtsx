                          UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT sfdc.BUS_ORG_NAME
	,sfdc.BUS_ORG_ID
	,sfdc.SALES_COUNTRY
	,sfdc.SUB_REGION
	,sfdc.SALES_DIVISION
	,sfdc.SALES_OFFICE
	,sfdc.SALES_OFFICE_OWNER
	,sfdc.REPORTING_SALES_CHANNEL
	,sfdc.SALES_CHANNEL_OWNER
	,sfdc.SALES_CHANNEL
	,sfdc.SALES_SUB_CHANNEL
	,sfdc.SEGMENT
	,sfdc.SUB_SEGMENT
	,sfdc.MARKET_VERTICAL
	,sfdc.MARKET_SUB_VERTICAL
	,sfdc.SALES_REGION_OWNER
	,sfdc.SALES_DIVISION_OWNER
	,sfdc.MANAGER_OWNER
	,sfdc.SOURCE_MANAGER_EMPLOYEE_NBR
	,ISNULL(gal.supervisor_person_id, sfdc.SOURCE_MANAGER_EMPLOYEE_NBR) AS MANAGER_PERSON_ID
	,sfdc.PRIMARY_AM_NAME
	,sfdc.SOURCE_EMPLOYEE_NBR
	,ISNULL(gal.Person_ID, sfdc.SOURCE_EMPLOYEE_NBR) AS PRIMARY_AM_PERSON_ID
	,sfdc.PRIMARY_AM_EMAIL
	,sfdc.PRIMARY_AM_OWNER_TYPE
	,sfdc.PRIMARY_AM_REGION
	,sfdc.SERVICE_LEVEL
	,sfdc.LEGACY_COMPANY
	,sfdc.CUSTOMER_TIER
	,sfdc.GAM
	,sfdc.Ultimate_Cust_Num
	,sfdc.Ultimate_Customer_Name
	,sfdc.CSM_FLAG
	,sfdc.CSM_NAME_1
	,sfdc.CSM_EMAIL_1
	,sfdc.CSM_EMPLOYEE_NBR_1
	,ISNULL(galcsm.Person_ID, sfdc.CSM_EMPLOYEE_NBR_1) AS CSM_PERSON_ID_1
	,sfdc.CSM_NAME_2
	,sfdc.CSM_NAME_3
	,sfdc.CSM_NAME_4
	,sfdc.CSM_NAME_5
	,sfdc.OSM_FLAG
	,sfdc.OSM_NAME
	,sfdc.OSM_EMAIL
	,sfdc.RVP_Name
	,sfdc.RVP_Employee_Nbr
	,ISNULL(galrvp.Person_ID, sfdc.RVP_Employee_Nbr) AS RVP_Person_ID
	,sfdc.RVP_Login
	,sfdc.RVP_Email
	,sfdc.GM_Market_SFDC
	,sfdc.General_Manager_VP_Name
	,sfdc.GM_NT_Login
	,sfdc.GM_Employee_Nbr
	,ISNULL(galgm.Person_ID, sfdc.GM_Employee_Nbr) AS GM_Person_ID
	,sfdc.GM_Email
	,sfdc.BU_SOURCE
	,ISNULL(bu.BUSINESS_UNIT, 'OTHER') AS BUSINESS_UNIT
	,ISNULL(bu.BU_SHORT, 'OTHER') AS BU_SHORT
	,sfdc.CUST_CONTACT_NAME
	,sfdc.CUST_CONTACT_EMAIL
	,sfdc.CUST_PHONE_NBR
	,sfdc.SP_Name
	,sfdc.SP_Employee_Nbr
	,ISNULL(galsp.Person_ID, sfdc.SP_Employee_Nbr) AS SP_Person_ID
	,sfdc.ACCOUNT_SALES_CHANNEL
	,sfdc.ACCT_OWNER_SALES_REGION
                ,sfdc.SD_PLUS
	,sfdc.TIER2_Manager
	,sfdc.TIER2_Manager_Nbr
	,ISNULL(galt2.Person_ID, sfdc.TIER2_Manager_Nbr) AS TIER2_Manager_Person_ID
	,sfdc.LOB_ID
	,sfdc.Director_Name
	,sfdc.Director_Employee_Nbr
	,ISNULL(galdir.Person_ID, sfdc.Director_Employee_Nbr) AS Director_Person_ID
	,sfdc.account_id
	,isNull(buSeg.bu_short, 'Unknown') bu_segment
	,sfdc.sales_rep_id
	,sfdc.enterprise_target_group_in_cou
	,isNull(bl2.bu_short, 'Unknown') bu_layer_2
	,coalesce(t0.bu_short, sfdc.gl_lob_ess_tier0_desc, 'Unknown') as lob_tier_0
	,coalesce(t1.bu_short, sfdc.gl_lob_ess_tier1_desc, 'Unknown') as lob_tier_1
	,coalesce(t2.bu_short, sfdc.gl_lob_ess_tier2_desc, 'Unknown') as lob_tier_2
	,coalesce(t6.bu_short, sfdc.gl_lob_ess_tier6_desc, 'Unknown') as lob_tier_6
	,coalesce(t7.bu_short, sfdc.gl_lob_ess_tier7_desc, 'Unknown') as lob_tier_7
	,coalesce(t8.bu_short, sfdc.gl_lob_ess_tier8_desc, 'Unknown') as lob_tier_8
	,coalesce(t9.bu_short, sfdc.gl_lob_ess_tier9_desc, 'Unknown') as lob_tier_9
	,coalesce(t10.bu_short, sfdc.gl_lob_ess_tier10_desc, 'Unknown') as lob_tier_10
	,coalesce(t11.bu_short, sfdc.gl_lob_ess_tier11_desc, 'Unknown') as lob_tier_11
	,sfdc.sales_as_managed
	,sfdc.sales_segment_leader
	,sfdc.sales_segment_leader_name
	,sfdc.cs_as_managed
	,sfdc.cs_segment_leader
	,sfdc.cs_segment_leader_name
	,sfdc.lob_description
	,sfdc.market
	,sfdc.market_alias
	,sfdc.gm_market
	,sfdc.cs_owner_name
	,sfdc.cs_owner_emp_nbr
	,sfdc.cs_owner_cuid
	,sfdc.dw_secure_company_nbr
FROM dbo.TBL_SFDC_ACCOUNT_STAGING sfdc
LEFT OUTER JOIN dbo.GALCapture gal
	ON gal.EMPLOYEE_NUMBER = sfdc.SOURCE_EMPLOYEE_NBR
LEFT OUTER JOIN dbo.GALCapture galcsm
	ON galcsm.EMPLOYEE_NUMBER = sfdc.CSM_EMPLOYEE_NBR_1
LEFT OUTER JOIN dbo.GALCapture galrvp
	ON galrvp.EMPLOYEE_NUMBER = sfdc.RVP_Employee_Nbr
LEFT OUTER JOIN dbo.GALCapture galgm
	ON galgm.EMPLOYEE_NUMBER = sfdc.GM_Employee_Nbr
LEFT OUTER JOIN dbo.GALCapture galsp
	ON galsp.EMPLOYEE_NUMBER = sfdc.SP_Employee_Nbr
LEFT OUTER JOIN dbo.GALCapture galt2
	ON galt2.EMPLOYEE_NUMBER = sfdc.TIER2_Manager_Nbr
LEFT OUTER JOIN dbo.GALCapture galdir
	ON galdir.EMPLOYEE_NUMBER = sfdc.Director_Employee_Nbr
LEFT OUTER JOIN dbo.REF_SFDC_BU_MAPPING bu
	ON sfdc.BU_SOURCE = bu.BU_SOURCE
		AND bu.category = 'BU'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping buSeg
	ON sfdc.bu_segment = buSeg.business_unit
		AND buSeg.category = 'BU_SEGMENT'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping bl2
	ON sfdc.bu_layer_2 = bl2.business_unit
		AND bl2.category = 'BU Layer 2'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t0
	ON sfdc.gl_lob_ess_tier0_desc = t0.business_unit
		AND bl2.category = 'Tier 0'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t1
	ON sfdc.gl_lob_ess_tier1_desc = t1.business_unit
		AND bl2.category = 'Tier 1'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t2
	ON sfdc.gl_lob_ess_tier2_desc = t2.business_unit
		AND bl2.category = 'Tier 2'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t6
	ON sfdc.gl_lob_ess_tier6_desc = t6.business_unit
		AND bl2.category = 'Tier 6'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t7
	ON sfdc.gl_lob_ess_tier7_desc = t7.business_unit
		AND bl2.category = 'Tier 7'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t8
	ON sfdc.gl_lob_ess_tier8_desc = t8.business_unit
		AND bl2.category = 'Tier 8'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t9
	ON sfdc.gl_lob_ess_tier9_desc = t9.business_unit
		AND bl2.category = 'Tier 9'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t10
	ON sfdc.gl_lob_ess_tier10_desc = t10.business_unit
		AND bl2.category = 'Tier 10'
LEFT OUTER JOIN dbo.ref_sfdc_bu_mapping t11
	ON sfdc.gl_lob_ess_tier11_desc = t11.business_unit
		AND bl2.category = 'Tier 11'</property>
