                      connectionManagerID="{FAC55B32-B295-4021-8F8E-88346C16C48E}:external"
                      connectionManagerRefId="Project.ConnectionManagers[OLEDB.CDW01P.sa_staging_appl]"
                      description="The OLE DB runtime connection used to access the database."
                      name="OleDbConnection" />
                  </connections>
                  <outputs>
                    <output
                      refId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output]"
                      name="OLE DB Source Output">
                      <outputColumns>
                        <outputColumn
                          refId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output].Columns[BUS_ORG_NAME]"
                          dataType="wstr"
                          errorOrTruncationOperation="Conversion"
                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output].ExternalColumns[BUS_ORG_NAME]"
                          length="100"
                          lineageId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output].Columns[BUS_ORG_NAME]"
                          name="BUS_ORG_NAME"
                          truncationRowDisposition="FailComponent" />
                        <outputColumn
                          refId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output].Columns[BUS_ORG_ID]"
                          dataType="wstr"
                          errorOrTruncationOperation="Conversion"
                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output].ExternalColumns[BUS_ORG_ID]"
                          length="30"
                          lineageId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output].Columns[BUS_ORG_ID]"
                          name="BUS_ORG_ID"
                          truncationRowDisposition="FailComponent" />
                        <outputColumn
                          refId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output].Columns[SALES_COUNTRY]"
                          dataType="wstr"
                          errorOrTruncationOperation="Conversion"
                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\OLE_SRC Get Account Data.Outputs[OLE DB Source Output].ExternalColumns[SALES_COUNTRY]"
                          length="30"
