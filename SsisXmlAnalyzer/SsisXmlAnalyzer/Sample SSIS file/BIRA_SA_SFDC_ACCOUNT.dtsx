                          refId="Package\SEQC Load SFDC Account Staging\DFT ETL TBL SFDC ACCOUNT STAGING\LOAD TBL SFDC ACCOUNT STAGING.Outputs[OLE DB Destination Error Output].Columns[ErrorCode]"
